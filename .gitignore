./Discord/node_modules

# User-specific stuff
/Tofu/.idea/

*.iml
*.ipr
*.iws

# IntelliJ
/Tofu/out/
# mpeltonen/sbt-idea plugin
/Tofu/.idea_modules/

# JIRA plugin
/Tofu/atlassian-ide-plugin.xml

# Compiled class file
*.class

# Log file
*.log

# BlueJ files
*.ctxt

# Package Files #
*.jar
*.war
*.nar
*.ear
*.zip
*.tar.gz
*.rar

# virtual machine crash logs, see http://www.java.com/en/download/help/error_hotspot.xml
hs_err_pid*

*~

# temporary files which can be created if a process still has a handle open of a deleted file
/Tofu/.fuse_hidden*

# KDE directory preferences
/Tofu/.directory

# Linux trash folder which might appear on any partition or disk
/Tofu/.Trash-*

# .nfs files are created when an open file is removed but is still being accessed
.nfs*

# General
/Tofu/.DS_Store
/Tofu/.AppleDouble
/Tofu/.LSOverride

# Icon must end with two \r
Icon

# Thumbnails
._*

# Files that might appear in the root of a volume
/Tofu/.DocumentRevisions-V100
/Tofu/.fseventsd
/Tofu/.Spotlight-V100
/Tofu/.TemporaryItems
/Tofu/.Trashes
/Tofu/.VolumeIcon.icns
/Tofu/.com.apple.timemachine.donotpresent

# Directories potentially created on remote AFP share
/Tofu/.AppleDB
/Tofu/.AppleDesktop
/Tofu/Network Trash Folder
/Tofu/Temporary Items
/Tofu/.apdisk

# Windows thumbnail cache files
/Tofu/Thumbs.db
/Tofu/Thumbs.db:encryptable
/Tofu/ehthumbs.db
/Tofu/ehthumbs_vista.db

# Dump file
*.stackdump

# Folder config file
[Dd]esktop.ini

# Recycle Bin used on file shares
/Tofu/$RECYCLE.BIN/

# Windows Installer files
*.cab
*.msi
*.msix
*.msm
*.msp

# Windows shortcuts
*.lnk

/Tofu/.gradle
/Tofu/build/

# Ignore Gradle GUI config
/Tofu/gradle-app.setting

# Cache of project
/Tofu/.gradletasknamecache

**/build/

# Common working directory
/Tofu/run/

# Avoid ignoring Gradle wrapper jar file (.jar files are usually ignored)
!gradle-wrapper.jar
